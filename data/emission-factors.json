{
  "_meta": {
    "title": "GreenCalculus Emission Factor Dataset",
    "description": "Curated emission factors for Scope 1 stationary combustion, Scope 2 electricity, and selected Scope 3 categories. All factors expressed in kg CO2e per unit unless noted.",
    "dataset_version": "2026.1",
    "published": "2026-05-10",
    "gwp_basis": "IPCC AR6 GWP-100",
    "license": "MIT",
    "canonical_url": "https://greencalculus.com/data/emission-factors/",
    "sources": {
      "DESNZ_2024": {
        "name": "UK DESNZ Greenhouse Gas Conversion Factors 2024",
        "publisher": "UK Department for Energy Security and Net Zero",
        "url": "https://www.gov.uk/government/collections/government-conversion-factors-for-company-reporting",
        "year": 2024
      },
      "EPA_2024": {
        "name": "EPA Emission Factors for Greenhouse Gas Inventories 2024",
        "publisher": "US Environmental Protection Agency",
        "url": "https://www.epa.gov/climateleadership/ghg-emission-factors-hub",
        "year": 2024
      },
      "IEA_2026": {
        "name": "IEA Global Energy Review 2026",
        "publisher": "International Energy Agency",
        "url": "https://www.iea.org/reports/global-energy-review",
        "year": 2026
      },
      "IPCC_2006": {
        "name": "IPCC 2006 Guidelines for National Greenhouse Gas Inventories",
        "publisher": "Intergovernmental Panel on Climate Change",
        "url": "https://www.ipcc-nggip.iges.or.jp/public/2006gl/",
        "year": 2006
      }
    }
  },
